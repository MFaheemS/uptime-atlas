DATABASE_URL=postgresql://uptime:uptime@localhost:5432/uptimeatlas
REDIS_URL=redis://localhost:6379
JWT_SECRET=changeme_use_a_long_random_string
JWT_REFRESH_SECRET=changeme_use_another_long_random_string
PORT=3001
NODE_ENV=development
# Email notifications via Resend (free tier: 3000 emails/month)
RESEND_API_KEY=re_your_api_key_here
# Default Resend test address — works without a custom domain on free tier
RESEND_FROM_EMAIL=onboarding@resend.dev
# Slack Incoming Webhook URL from api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Frontend app URL used in email links
APP_URL=http://localhost:3000
