generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  name                    String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  monitors                Monitor[]
  refreshTokens           RefreshToken[]
  notificationPreferences NotificationPreferences?
  apiKeys                 ApiKey[]
  deviceTokens            DeviceToken[]
  pushPreferences         MonitorPushPreference[]
}

model NotificationPreferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertOnDown         Boolean  @default(true)
  alertOnRecovered    Boolean  @default(true)
  alertOnSslExpiry    Boolean  @default(true)
  weeklyDigestEnabled Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Monitor {
  id                   String                @id @default(cuid())
  userId               String
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  url                  String
  slug                 String?               @unique
  intervalMinutes      Int                   @default(5)
  active               Boolean               @default(true)
  alertThreshold       Int                   @default(2)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  checkResults         CheckResult[]
  incidents            Incident[]
  notificationChannels NotificationChannel[]
  stats                MonitorStats[]
  anomalyEvents        AnomalyEvent[]
}

model CheckResult {
  id              String   @id @default(cuid())
  monitorId       String
  monitor         Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status          Int
  responseTimeMs  Int
  isUp            Boolean
  checkedAt       DateTime @default(now())
  region          String   @default("us-east")
  error           String?
  sslExpiryDays   Int?
  dnsResolutionMs Int?
  anomalyEvents   AnomalyEvent[]
}

model Incident {
  id         String    @id @default(cuid())
  monitorId  String
  monitor    Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  startedAt  DateTime  @default(now())
  resolvedAt DateTime?
  durationMs Int?
  aiSummary  String?
  createdAt  DateTime  @default(now())
}

enum NotificationChannelType {
  EMAIL
  SLACK
  WEBHOOK
}

enum AlertType {
  DOWN
  RECOVERED
  SSL_EXPIRY
}

model NotificationChannel {
  id        String                  @id @default(cuid())
  monitorId String
  monitor   Monitor                 @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  type      NotificationChannelType
  target    String
  active    Boolean                 @default(true)
  createdAt DateTime                @default(now())
  alertLogs ChannelAlertLog[]
}

model ChannelAlertLog {
  id        String              @id @default(cuid())
  monitorId String
  channelId String
  channel   NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  alertType AlertType
  sentAt    DateTime            @default(now())
}

model MonitorStats {
  id                String   @id @default(cuid())
  monitorId         String
  monitor           Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  periodDays        Int
  uptimePercent     Float
  totalChecks       Int
  totalIncidents    Int
  avgResponseTimeMs Float
  calculatedAt      DateTime @default(now())

  @@unique([monitorId, periodDays])
}

model AnomalyEvent {
  id                  String      @id @default(cuid())
  monitorId           String
  monitor             Monitor     @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  checkResultId       String
  checkResult         CheckResult @relation(fields: [checkResultId], references: [id], onDelete: Cascade)
  zScore              Float
  responseTimeMs      Int
  meanResponseTimeMs  Float
  detectedAt          DateTime    @default(now())
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonitorPushPreference {
  id        String   @id @default(cuid())
  userId    String
  monitorId String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, monitorId])
}
